{
  "name": "chatgpt-full-exporter",
  "version": "2.0.1",
  "description": "Export all your ChatGPT conversations, projects & GPTs as JSON, Markdown and HTML",
  "type": "module",
  "bin": {
    "chatgpt-full-exporter": "./bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezwep/chatgpt-exporter.git"
  },
  "homepage": "https://github.com/ezwep/chatgpt-exporter#readme",
  "bugs": {
    "url": "https://github.com/ezwep/chatgpt-exporter/issues"
  },
  "files": [
    "server.js",
    "bin/",
    "public/"
  ],
  "scripts": {
    "start": "node server.js",
    "build": "npx esbuild server.js --bundle --platform=node --format=cjs --outfile=bundle.cjs && npx @yao-pkg/pkg bundle.cjs --targets node18-win-x64 --output dist/chatgpt-exporter-win.exe && node -e \"const{cpSync}=require('fs');cpSync('public','dist/public',{recursive:true})\""
  },
  "keywords": [
    "chatgpt",
    "chatgpt-backup",
    "chatgpt-export",
    "chatgpt-exporter",
    "chatgpt-archive",
    "openai",
    "gpt",
    "backup",
    "export",
    "exporter",
    "archive",
    "archiver",
    "conversations",
    "projects",
    "custom-gpts",
    "data-portability",
    "gdpr",
    "self-hosted",
    "markdown",
    "json"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "scripts": "bundle.cjs",
    "assets": ["public/**/*"],
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  }
}
